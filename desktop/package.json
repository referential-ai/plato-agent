{
	"name": "desktop",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build --no-bundle",
		"stage:windows-sidecar": "node scripts/stage-windows-sidecar.mjs",
		"tauri:bundle:windows": "npm run stage:windows-sidecar && tauri build --target x86_64-pc-windows-msvc --bundles nsis --config src-tauri/tauri.windows-package.conf.json --no-sign",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@lucide/svelte": "^1.24.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tauri-apps/cli": "^2.11.4",
		"@vitest/browser-playwright": "^4.1.8",
		"clsx": "^2.1.1",
		"playwright": "^1.60.0",
		"shadcn-svelte": "^1.4.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.1"
	}
}
