{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Plato",
  "version": "0.1.0",
  "identifier": "ai.referential.plato",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Plato Agent",
        "width": 1180,
        "height": 760,
        "minWidth": 760,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; font-src 'self'; img-src 'self' data:; style-src 'self'",
      "devCsp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:5173 ws://localhost:5173; font-src 'self'; img-src 'self' data:; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'",
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
